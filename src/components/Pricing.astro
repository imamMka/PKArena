---
const icons = {
  fire: "https://raw.githubusercontent.com/microsoft/fluentui-emoji/main/assets/Fire/3D/fire_3d.png",
  timer:
    "https://raw.githubusercontent.com/microsoft/fluentui-emoji/main/assets/Hourglass指标/3D/hourglass_done_3d.png",
  crown:
    "https://raw.githubusercontent.com/microsoft/fluentui-emoji/main/assets/Crown/3D/crown_3d.png",
};

const admin = "621219118993";

const getWaLink = (paket: string) => {
  const message = `Halo Admin, saya tertarik untuk booking paket *${paket}*. Mohon info ketersediaan slotnya. Terima kasih!`;
  return `https://wa.me/${admin}?text=${encodeURIComponent(message)}`;
};
